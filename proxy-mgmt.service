[Unit]
Description=Proxy Management Service
After=network.target
StartLimitBurst=5
StartLimitIntervalSec=60s
OnFailure=notify-admin@%n.service

[Service]
Type=simple
EnvironmentFile=/etc/proxy_mgt.env
ExecStart=/usr/bin/python3 /path/to/proxy_mgt.py --password ${PROXY_PASSWORD} --user ${PROXY_USER} --host ${PROXY_HOST} --port ${PROXY_PORT}
Restart=always
RestartSec=5s
User=root
Group=root

[Install]
WantedBy=multi-user.target
