#!/usr/bin/env python3
import argparse
import base64
import csv
import json
import os
import subprocess
import sys
import tempfile
import time

try:
    import fcntl  # type: ignore
except Exception:  # pragma: no cover
    fcntl = None


def run_root(cmd: list[str], check: bool = True) -> subprocess.CompletedProcess:
    if os.geteuid() == 0:
        p = subprocess.run(cmd, text=True)
    else:
        p = subprocess.run(["sudo", *cmd], text=True)
    if check and p.returncode != 0:
        raise SystemExit(p.returncode)
    return p


def read_rows(log_file: str) -> list[dict]:
    with open(log_file, "r", encoding="utf-8") as f:
        reader = csv.DictReader(f, delimiter="\t")
        return [r for r in reader if r.get("round_id")]


def latest_round_id(rows: list[dict]) -> str:
    # File is append-only; last row is newest.
    return rows[-1]["round_id"]


def pick_row(rows: list[dict], round_id: str, rank: int) -> dict:
    candidates = [r for r in rows if r.get("round_id") == round_id]
    if not candidates:
        raise SystemExit(f"error: no rows for round_id={round_id}")
    for r in candidates:
        try:
            if int(r.get("rank") or 0) == int(rank):
                return r
        except Exception:
            continue
    raise SystemExit(f"error: rank {rank} not found for round_id={round_id}")


def _b64decode_any(s: str) -> bytes:
    s = (s or "").strip()
    s = s.replace("\n", "").replace("\r", "")
    pad = "=" * ((4 - (len(s) % 4)) % 4)
    s_padded = s + pad
    try:
        return base64.urlsafe_b64decode(s_padded.encode("utf-8"))
    except Exception:
        return base64.b64decode(s_padded.encode("utf-8"))


def parse_vmess_uri(vmess_uri: str) -> dict:
    vmess_uri = (vmess_uri or "").strip()
    if not vmess_uri.startswith("vmess://"):
        raise SystemExit("error: vmess_uri missing or invalid in TSV")
    payload_b64 = vmess_uri[len("vmess://") :]
    try:
        payload = _b64decode_any(payload_b64).decode("utf-8", errors="strict")
        obj = json.loads(payload)
    except Exception as e:
        raise SystemExit(f"error: failed to decode vmess_uri: {e}")

    addr = obj.get("add") or ""
    port = int(obj.get("port") or 0)
    uuid = obj.get("id") or ""
    alter_id = int(obj.get("aid") or 0)
    security = obj.get("scy") or "auto"
    network = obj.get("net") or "ws"
    host = obj.get("host") or ""
    path = obj.get("path") or "/"
    tls = str(obj.get("tls") or "").lower() in ("tls", "1", "true", "yes")
    sni = obj.get("sni") or host or ""

    if not addr or not port or not uuid:
        raise SystemExit("error: vmess payload missing add/port/id")

    return {
        "addr": addr,
        "port": port,
        "uuid": uuid,
        "alter_id": alter_id,
        "security": security,
        "network": network,
        "host": host,
        "path": path,
        "tls": tls,
        "sni": sni,
    }


def update_config_proxy_outbound(config: dict, node: dict) -> dict:
    outbounds = config.get("outbounds") or []
    proxy = None
    for ob in outbounds:
        if isinstance(ob, dict) and ob.get("tag") == "proxy":
            proxy = ob
            break
    if proxy is None:
        raise SystemExit("error: no outbound tag=proxy found in /usr/local/etc/v2ray/config.json")

    proxy["protocol"] = "vmess"
    proxy["settings"] = {
        "vnext": [
            {
                "address": node["addr"],
                "port": node["port"],
                "users": [
                    {
                        "id": node["uuid"],
                        "alterId": node["alter_id"],
                        "security": node["security"],
                    }
                ],
            }
        ]
    }

    stream = {"network": node["network"], "security": "tls" if node["tls"] else "none"}
    if node["tls"]:
        stream["tlsSettings"] = {"serverName": node["sni"] or node["host"] or node["addr"], "allowInsecure": False}
    if node["network"] == "ws":
        ws = {"path": node["path"] or "/"}
        if node["host"]:
            ws["headers"] = {"Host": node["host"]}
        stream["wsSettings"] = ws
    proxy["streamSettings"] = stream
    return config


def write_config_atomically(path: str, config: dict, rid: str):
    directory = os.path.dirname(path) or "."
    # v2ray uses file extension to pick the config loader; keep a .json suffix.
    tmp_fd, tmp_path = tempfile.mkstemp(prefix=".config.json.", suffix=".tmp.json", dir=directory)
    try:
        with os.fdopen(tmp_fd, "w", encoding="utf-8") as f:
            json.dump(config, f, indent=2, ensure_ascii=False)
            f.write("\n")

        run_root(["v2ray", "test", "-config", tmp_path], check=True)

        run_root(["chmod", "0640", tmp_path], check=True)
        try:
            run_root(["chown", "root:v2ray", tmp_path], check=True)
        except Exception:
            pass

        backup = f"{path}.bak-bench-{time.strftime('%Y%m%d-%H%M%S')}-{rid}"
        run_root(["cp", "-a", path, backup], check=True)
        run_root(["mv", "-f", tmp_path, path], check=True)
    finally:
        try:
            os.unlink(tmp_path)
        except Exception:
            pass


def main() -> int:
    ap = argparse.ArgumentParser(
        prog="v2ray-bench-apply",
        description="Apply a selected best node from /var/log/v2ray-bench.tsv to the running v2ray.service.",
    )
    ap.add_argument("--log-file", default="/var/log/v2ray-bench.tsv", help="TSV produced by v2ray-bench-nodes.")
    ap.add_argument("--round-id", default="", help="Use a specific round_id (default: latest).")
    ap.add_argument("--rank", type=int, default=1, help="Pick which rank to apply from that round (default: 1).")
    ap.add_argument(
        "--method",
        choices=["vmess", "subscribe"],
        default="vmess",
        help="vmess: apply TSV vmess_uri (recommended). subscribe: call v2ray-subscribe --select (may mismatch if subscription changed).",
    )
    ap.add_argument(
        "--select-field",
        choices=["idx", "addr", "ps"],
        default="idx",
        help="Which field to pass into v2ray-subscribe --select (default: idx).",
    )
    ap.add_argument(
        "--url",
        default="",
        help="Override subscription URL (default: use url column in TSV).",
    )
    ap.add_argument("--socks", type=int, default=1080, help="SOCKS inbound port (default: 1080).")
    ap.add_argument("--http", type=int, default=8080, help="HTTP inbound port (default: 8080).")
    ap.add_argument("--dry-run", action="store_true", help="Print what would be applied, but do nothing.")
    args = ap.parse_args()

    if not os.path.exists(args.log_file):
        print(f"error: log file not found: {args.log_file}", file=sys.stderr)
        return 2

    rows = read_rows(args.log_file)
    if not rows:
        print("error: no rows in log file", file=sys.stderr)
        return 2

    rid = args.round_id.strip() or latest_round_id(rows)
    row = pick_row(rows, rid, args.rank)

    url = args.url.strip() or (row.get("url") or "").strip()
    if not url:
        print("error: missing url (pass --url or ensure TSV has url column)", file=sys.stderr)
        return 2

    addr = (row.get("addr") or "").strip()
    port = (row.get("port") or "").strip()
    speed = (row.get("speed_Bps") or "").strip()
    started_at = (row.get("started_at") or "").strip()
    print(f"round_id={rid} started_at={started_at} rank={args.rank} addr={addr}:{port} speed_Bps={speed}")
    print(f"url={url}")

    if args.dry_run:
        return 0

    config_path = "/usr/local/etc/v2ray/config.json"
    lock_path = "/var/lock/v2ray-bench-apply.lock"
    os.makedirs(os.path.dirname(lock_path) or ".", exist_ok=True)
    lock_fd = os.open(lock_path, os.O_WRONLY | os.O_CREAT, 0o644)
    try:
        if fcntl is not None:
            try:
                fcntl.flock(lock_fd, fcntl.LOCK_EX)
            except Exception:
                pass

        if args.method == "vmess":
            node = parse_vmess_uri((row.get("vmess_uri") or "").strip())
            with open(config_path, "r", encoding="utf-8") as f:
                cfg = json.load(f)
            cfg2 = update_config_proxy_outbound(cfg, node)
            write_config_atomically(config_path, cfg2, rid)
        else:
            if args.select_field == "idx":
                select_value = str(int(float(row.get("idx") or 0)))
            elif args.select_field == "addr":
                select_value = (row.get("addr") or "").strip()
            else:
                select_value = (row.get("ps") or "").strip()

            if not select_value:
                print(f"error: empty select value for field {args.select_field}", file=sys.stderr)
                return 2

            print(f"select_field={args.select_field} select={select_value}")
            run_root(
                [
                    "/usr/local/bin/v2ray-subscribe",
                    "update",
                    "--url",
                    url,
                    "--select",
                    select_value,
                    "--socks",
                    str(args.socks),
                    "--http",
                    str(args.http),
                ],
                check=True,
            )
    finally:
        try:
            os.close(lock_fd)
        except Exception:
            pass

    run_root(["systemctl", "restart", "v2ray.service"], check=True)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
