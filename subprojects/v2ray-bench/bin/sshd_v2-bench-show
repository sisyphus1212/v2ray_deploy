#!/usr/bin/env python3
import argparse
import csv
import os
import sys
from collections import defaultdict


def parse_rows(path: str) -> list[dict]:
    with open(path, "r", encoding="utf-8") as f:
        reader = csv.DictReader(f, delimiter="\t")
        return [r for r in reader if any(v for v in r.values())]


def to_int(s: str, default: int = 0) -> int:
    try:
        return int(float(s))
    except Exception:
        return default


def to_float(s: str, default: float = 0.0) -> float:
    try:
        return float(s)
    except Exception:
        return default


def pad(s: str, w: int) -> str:
    s = "" if s is None else str(s)
    if len(s) <= w:
        return s + (" " * (w - len(s)))
    if w <= 1:
        return s[:w]
    return s[: w - 1] + "…"


def print_table(rows: list[dict], columns: list[tuple[str, int]]):
    header = " ".join(pad(name, width) for name, width in columns)
    print(header)
    print("-" * len(header))
    for r in rows:
        line = " ".join(pad(r.get(name, ""), width) for name, width in columns)
        print(line)


def latest_round_id(rows: list[dict]) -> str:
    for r in reversed(rows):
        rid = (r.get("round_id") or "").strip()
        if rid:
            return rid
    return ""


def group_by_round(rows: list[dict]) -> dict[str, list[dict]]:
    g: dict[str, list[dict]] = defaultdict(list)
    for r in rows:
        rid = (r.get("round_id") or "").strip()
        if rid:
            g[rid].append(r)
    return g


def round_summary(round_rows: list[dict]) -> dict:
    # pick rank==1 if present, else max speed
    best = None
    for r in round_rows:
        if to_int(r.get("rank") or "", 0) == 1:
            best = r
            break
    if best is None:
        best = max(round_rows, key=lambda x: to_int(x.get("speed_Bps") or "0", 0), default={})

    started_at = (best.get("started_at") or "").strip() or (round_rows[0].get("started_at") or "").strip()
    url = (best.get("url") or "").strip()
    addr = (best.get("addr") or "").strip()
    port = (best.get("port") or "").strip()
    speed = to_int(best.get("speed_Bps") or "0", 0)
    return {
        "round_id": (best.get("round_id") or "").strip(),
        "started_at": started_at,
        "url": url,
        "best": f"{addr}:{port}",
        "speed_Bps": str(speed),
    }


def main() -> int:
    ap = argparse.ArgumentParser(
        prog="sshd_v2-bench-show",
        description="Human-friendly viewer for /var/log/sshd_v2-bench.tsv.",
    )
    ap.add_argument("--log-file", default="/var/log/sshd_v2-bench.tsv", help="TSV log path.")
    ap.add_argument("--round-id", default="", help="Show a specific round_id (default: latest).")
    ap.add_argument("--top", type=int, default=10, help="Show top N rows for that round (default: 10).")
    ap.add_argument("--summary", action="store_true", help="Show round summaries instead of per-node rows.")
    ap.add_argument("--last-rounds", type=int, default=10, help="How many latest rounds to show in summary (default: 10).")
    ap.add_argument("--tsv", action="store_true", help="Output raw TSV for the selection.")
    args = ap.parse_args()

    if not os.path.exists(args.log_file):
        print(f"error: log file not found: {args.log_file}", file=sys.stderr)
        return 2

    rows = parse_rows(args.log_file)
    if not rows:
        print("error: log file is empty", file=sys.stderr)
        return 2

    by_round = group_by_round(rows)
    if not by_round:
        print("error: no round_id rows found", file=sys.stderr)
        return 2

    # latest rounds list in file order
    seen = set()
    ordered_rounds: list[str] = []
    for r in rows:
        rid = (r.get("round_id") or "").strip()
        if rid and rid not in seen:
            seen.add(rid)
            ordered_rounds.append(rid)

    if args.summary:
        tail = ordered_rounds[-max(1, int(args.last_rounds)) :]
        out = [round_summary(by_round[rid]) for rid in tail]
        if args.tsv:
            print("round_id\tstarted_at\turl\tbest\tspeed_Bps")
            for r in out:
                print(f"{r['round_id']}\t{r['started_at']}\t{r['url']}\t{r['best']}\t{r['speed_Bps']}")
            return 0
        print_table(
            out,
            [
                ("round_id", 20),
                ("started_at", 19),
                ("url", 34),
                ("best", 22),
                ("speed_Bps", 10),
            ],
        )
        return 0

    rid = args.round_id.strip() or latest_round_id(rows)
    if not rid or rid not in by_round:
        print(f"error: round_id not found: {rid}", file=sys.stderr)
        return 2

    rr = list(by_round[rid])
    rr.sort(key=lambda r: (to_int(r.get("rank") or "9999", 9999), -to_int(r.get("speed_Bps") or "0", 0)))
    rr = rr[: max(1, int(args.top))]

    if args.tsv:
        # preserve common columns if present
        cols = [
            "round_id",
            "started_at",
            "url",
            "rank",
            "idx",
            "addr",
            "port",
            "http_code",
            "speed_Bps",
            "time_s",
            "exit_ip",
            "ps",
        ]
        print("\t".join(cols))
        for r in rr:
            print("\t".join((r.get(c) or "").replace("\t", " ") for c in cols))
        return 0

    print(f"round_id={rid}")
    print_table(
        rr,
        [
            ("rank", 4),
            ("url", 34),
            ("idx", 4),
            ("addr", 18),
            ("port", 5),
            ("http_code", 4),
            ("speed_Bps", 10),
            ("time_s", 7),
            ("exit_ip", 15),
            ("ps", 28),
        ],
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

